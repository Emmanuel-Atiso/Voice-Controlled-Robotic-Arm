#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <Servo.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

Servo baseServo;
Servo shoulderServo;
Servo elbowServo;
Servo wristServo;
Servo gripServo;

String input = "";

// ---------------- CURRENT POSITIONS ----------------
int basePos = 90;
int shoulderPos = 120;
int elbowPos = 60;
int wristPos = 90;
int gripPos = 70;

// ---------------- CALIBRATED POSES ----------------
int baseReset = 90;
int shoulderUp = 130;
int elbowUp = 60;
int wristUp = 90;

int shoulderLiftMid = 100;
int elbowLiftMid = 75;
int wristLiftMid = 95;

int shoulderPick = 85;
int elbowPick = 95;
int wristPick = 100;

// ---------------- GRIP ----------------
int gripOpen = 70;
int gripClose = 140;

// ---------------- STEP SIZES ----------------
int baseStepSmall = 10;
int baseStep = 20;
int baseStepBig = 35;

int shoulderStepSmall = 4;
int shoulderStep = 8;
int shoulderStepBig = 14;

int elbowStepSmall = 4;
int elbowStep = 8;
int elbowStepBig = 14;

int wristStepSmall = 2;
int wristStep = 4;
int wristStepBig = 8;

// ---------------- SAFE LIMITS ----------------
int baseMin = 0;
int baseMax = 180;

int shoulderMin = 60;
int shoulderMax = 150;

int elbowMin = 40;
int elbowMax = 150;

int wristMin = 60;
int wristMax = 130;

// ---------------- DISPLAY ----------------
void showCommand(String cmd) {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.println("Robot Arm");

  display.setTextSize(2);
  display.setCursor(0, 20);
  display.println(cmd);

  display.display();
}

void showLimit(String msg) {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.println("LIMIT REACHED");

  display.setTextSize(2);
  display.setCursor(0, 20);
  display.println(msg);

  display.display();

  Serial.print("Limit reached: ");
  Serial.println(msg);
}

// ---------------- SMOOTH MOVEMENT ----------------
void moveArmSmooth(int targetShoulder, int targetElbow, int targetWrist) {
  while (shoulderPos != targetShoulder ||
         elbowPos != targetElbow ||
         wristPos != targetWrist) {

    if (shoulderPos < targetShoulder) shoulderPos++;
    else if (shoulderPos > targetShoulder) shoulderPos--;

    if (elbowPos < targetElbow) elbowPos++;
    else if (elbowPos > targetElbow) elbowPos--;

    if (wristPos < targetWrist) wristPos++;
    else if (wristPos > targetWrist) wristPos--;

    shoulderServo.write(shoulderPos);
    elbowServo.write(elbowPos);
    wristServo.write(wristPos);

    delay(15);
  }
}

void moveBaseTo(int target) {
  if (target > baseMax) {
    target = baseMax;
    showLimit("BASE MAX");
  } else if (target < baseMin) {
    target = baseMin;
    showLimit("BASE MIN");
  }

  while (basePos != target) {
    if (basePos < target) basePos++;
    else basePos--;

    baseServo.write(basePos);
    delay(10);
  }
}

void moveBase(int amount) {
  moveBaseTo(basePos + amount);
}

void moveArm(int sStep, int eStep, int wStep) {
  int targetShoulder = shoulderPos + sStep;
  int targetElbow = elbowPos + eStep;
  int targetWrist = wristPos + wStep;

  bool limitHit = false;
  String limitMsg = "";

  if (targetShoulder > shoulderMax) {
    targetShoulder = shoulderMax;
    limitHit = true;
    limitMsg = "S2 MAX";
  } else if (targetShoulder < shoulderMin) {
    targetShoulder = shoulderMin;
    limitHit = true;
    limitMsg = "S2 MIN";
  }

  if (targetElbow > elbowMax) {
    targetElbow = elbowMax;
    limitHit = true;
    limitMsg = "S3 MAX";
  } else if (targetElbow < elbowMin) {
    targetElbow = elbowMin;
    limitHit = true;
    limitMsg = "S3 MIN";
  }

  if (targetWrist > wristMax) {
    targetWrist = wristMax;
    limitHit = true;
    limitMsg = "S4 MAX";
  } else if (targetWrist < wristMin) {
    targetWrist = wristMin;
    limitHit = true;
    limitMsg = "S4 MIN";
  }

  if (limitHit) {
    showLimit(limitMsg);
  }

  moveArmSmooth(targetShoulder, targetElbow, targetWrist);
}

// ---------------- GRIP ----------------
void openGrip() {
  while (gripPos != gripOpen) {
    if (gripPos < gripOpen) gripPos++;
    else gripPos--;

    gripServo.write(gripPos);
    delay(10);
  }
}

void closeGrip() {
  while (gripPos != gripClose) {
    if (gripPos < gripClose) gripPos++;
    else gripPos--;

    gripServo.write(gripPos);
    delay(10);
  }
}

// ---------------- PRESET POSES ----------------
void goFullyUp() {
  moveArmSmooth(shoulderUp, elbowUp, wristUp);
}

void goLiftMid() {
  moveArmSmooth(shoulderLiftMid, elbowLiftMid, wristLiftMid);
}

void goPickPose() {
  moveArmSmooth(shoulderPick, elbowPick, wristPick);
}

void resetPosition() {
  moveBaseTo(baseReset);
  goFullyUp();
}

// ---------------- TASK COMMANDS ----------------
void pickObject() {
  goPickPose();
  delay(500);

  closeGrip();
  delay(800);

  goLiftMid();
  delay(500);

  goFullyUp();
  delay(500);

  goFullyUp();
  delay(300);

  closeGrip();
}

void dropObject() {
  goLiftMid();
  delay(300);

  goPickPose();
  delay(500);

  openGrip();
  delay(500);

  goLiftMid();
  delay(300);

  goFullyUp();
  delay(500);

  goFullyUp();
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(9600);

  baseServo.attach(9);
  shoulderServo.attach(6);
  elbowServo.attach(5);
  wristServo.attach(3);
  gripServo.attach(11);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    for (;;);
  }

  baseServo.write(basePos);
  shoulderServo.write(shoulderPos);
  elbowServo.write(elbowPos);
  wristServo.write(wristPos);
  gripServo.write(gripPos);

  delay(500);

  resetPosition();
  openGrip();
  showCommand("READY");
}

// ---------------- LOOP ----------------
void loop() {
  while (Serial.available()) {
    char c = Serial.read();

    if (c == '\n') {
      input.trim();
      input.toUpperCase();

      if (input == "LEFT_SMALL") {
        moveBase(baseStepSmall);
        showCommand("L SMALL");
      }
      else if (input == "LEFT") {
        moveBase(baseStep);
        showCommand("LEFT");
      }
      else if (input == "LEFT_MORE") {
        moveBase(baseStepBig);
        showCommand("L MORE");
      }
      else if (input == "RIGHT_SMALL") {
        moveBase(-baseStepSmall);
        showCommand("R SMALL");
      }
      else if (input == "RIGHT") {
        moveBase(-baseStep);
        showCommand("RIGHT");
      }
      else if (input == "RIGHT_MORE") {
        moveBase(-baseStepBig);
        showCommand("R MORE");
      }
      else if (input == "DOWN_SMALL") {
        moveArm(-shoulderStepSmall, elbowStepSmall, wristStepSmall);
        showCommand("D SMALL");
      }
      else if (input == "DOWN") {
        moveArm(-shoulderStep, elbowStep, wristStep);
        showCommand("DOWN");
      }
      else if (input == "DOWN_MORE") {
        moveArm(-shoulderStepBig, elbowStepBig, wristStepBig);
        showCommand("D MORE");
      }
      else if (input == "UP_SMALL") {
        moveArm(shoulderStepSmall, -elbowStepSmall, -wristStepSmall);
        showCommand("U SMALL");
      }
      else if (input == "UP") {
        moveArm(shoulderStep, -elbowStep, -wristStep);
        showCommand("UP");
      }
      else if (input == "UP_MORE") {
        moveArm(shoulderStepBig, -elbowStepBig, -wristStepBig);
        showCommand("U MORE");
      }
      else if (input == "OPEN") {
        openGrip();
        showCommand("OPEN");
      }
      else if (input == "CLOSE") {
        closeGrip();
        showCommand("CLOSE");
      }
      else if (input == "RESET") {
        resetPosition();
        showCommand("RESET");
      }
      else if (input == "PICK") {
        pickObject();
        showCommand("PICK");
      }
      else if (input == "DROP") {
        dropObject();
        showCommand("DROP");
      }
      else {
        showCommand("UNKNOWN");
        Serial.print("Unknown command: ");
        Serial.println(input);
      }

      input = "";
    } else {
      input += c;
    }
  }
}
